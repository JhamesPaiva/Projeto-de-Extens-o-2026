# Modelo de Variáveis de Ambiente para EventoCom
# Copie este arquivo como .env na pasta backend/
#
# Instruções:
# 1. Copie este arquivo: cp .env.example .env
# 2. Editee os valores conforme necessário
# 3. NÃO compartilhe o arquivo .env em repositórios públicos

# ============================================================================
# SEGURANÇA - MUDAR ANTES DE PRODUÇÃO!
# ============================================================================
# Gere chaves fortes (64 chars) com PowerShell:
# $chars='abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_'
# -join (1..64 | ForEach-Object { $chars[(Get-Random -Minimum 0 -Maximum $chars.Length)] })
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-jwt

# ============================================================================
# BANCO DE DADOS - MYSQL
# ============================================================================

# Host do MySQL
DB_HOST=127.0.0.1

# Porta padrão do MySQL
DB_PORT=3306

# Usuário do MySQL (padrão: root)
DB_USER=root

# Senha do MySQL (deixe vazio se não tiver senha)
DB_PASSWORD=

# Nome do banco de dados
DB_NAME=eventocom

# Tamanho do pool de conexões (5 = suficiente para desenvolvimento)
DB_POOL_SIZE=5

# ============================================================================
# FLASK - CONFIGURAÇÕES DO SERVIDOR
# ============================================================================

# Modo debug (True = ativa recarregamento automático, False = produção)
# FLASK_ENV=development
# FLASK_DEBUG=1

# ============================================================================
# EXEMPLOS DE CONFIGURAÇÃO
# ============================================================================

# Exemplo 1: Produção com senha
# DB_PASSWORD=MinhaSenh@Forte123
# SECRET_KEY=kR9xL2pQ7mNv3hJ5tY8zB1dF4gW6sX0cZ
# JWT_SECRET_KEY=aB5cD9eF3gH7iJ1kL5mN9oP3qR7sT1uV5

# Exemplo 2: Desenvolvimento local sem senha (padrão)
# DB_PASSWORD=
# SECRET_KEY=change-me
# JWT_SECRET_KEY=change-me-jwt

# Exemplo 3: Usando Docker MySQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=eventocom
# DB_PASSWORD=eventocom_password
# DB_NAME=eventocom_db

# URL do servidor Flask
FLASK_URL=http://localhost:3000
